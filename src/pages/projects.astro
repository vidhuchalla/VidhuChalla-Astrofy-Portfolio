---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">

  <div>
    <div class="text-3xl w-full font-bold mb-5">
      My Projects {"</>"}
    </div>
  </div>

  <HorizontalCard
    title="Python Calculator"
    img="/post_img.webp"
    desc="A command-line calculator developed in Python that performs arithmetic operations using functions, conditional logic, and user input handling. This project helped strengthen my programming fundamentals and debugging skills."
    url="https://github.com/vidhuchalla"
    badge="Python"
  />

  <div class="divider my-0"></div>

  <HorizontalCard
    title="Personal Portfolio Website"
    img="/post_img.webp"
    desc="A personal website built using Astro and TailwindCSS to showcase my programming projects, technical skills, and interests in computer science and artificial intelligence."
    url="https://github.com/vidhuchalla"
    badge="Web Development"
  />

  <div class="divider my-0"></div>

  <HorizontalCard
    title="AI Hackathon Project"
    img="/post_img.webp"
    desc="An artificial intelligence project created during a school hackathon that received the Best AI Project Award. The project explored the use of AI to solve real-world problems."
    url="#"
    badge="AI"
  />

</BaseLayout>