---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Profile</div>
  </div>

  <div class="mb-10 text-justify">
    I am a high school student at American High School interested in computer
    science, artificial intelligence, and software development. I enjoy
    building programming projects, learning new technologies, and exploring
    how technology can be used to solve real-world problems. I am currently
    developing my skills in Python, data science, and machine learning.
  </div>


  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">

    <TimeLineElement
      title="American High School"
      subtitle="2022 - 2026 | Fremont, California"
    >
      High School Diploma<br />
      GPA: 3.63 / 4.00
    </TimeLineElement>

  </div>


  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

  <div class="time-line-container mb-10">

    <TimeLineElement
      title="Data Science Club Member"
      subtitle="2024 - Present | American High School"
    >
      Participated in activities focused on data science, artificial
      intelligence, and machine learning. Collaborated with peers to explore
      programming concepts and emerging technologies.
    </TimeLineElement>

    <TimeLineElement
      title="AI Hackathon Participant - Best AI Project Award"
      subtitle="School Hackathon"
    >
      Developed an artificial intelligence project that was recognized with
      the Best AI Project Award. Worked with a team to design and present an
      AI-based solution to address a real-world problem.
    </TimeLineElement>

    <TimeLineElement
      title="Python Calculator Project"
      subtitle="Personal Project | 2025"
    >
      Created a command-line calculator using Python. Implemented functions,
      conditional logic, user input handling, and debugging practices to
      build a functional application.
    </TimeLineElement>

  </div>


  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Certifications</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li>
      Currently pursuing additional experience in artificial intelligence,
      machine learning, and software development.
    </li>
  </ul>


  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills</div>
  </div>

  <ul class="list-disc md:columns-3 columns-2 mx-6">
    <li>Python</li>
    <li>Git</li>
    <li>GitHub</li>
    <li>Visual Studio Code</li>
    <li>Problem Solving</li>
    <li>Debugging</li>
    <li>Artificial Intelligence</li>
    <li>Machine Learning</li>
    <li>Data Science</li>
    <li>Object-Oriented Programming</li>
  </ul>

</BaseLayout>